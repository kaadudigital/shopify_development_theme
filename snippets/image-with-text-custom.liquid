{% comment %}theme-check-disable MissingTemplate{% endcomment %}
{%- liquid
  if display_on_card
    assign desktop_sizes_base = 'calc(100vw - 5rem)'
    assign mobile_sizes_base = 'calc(100vw - 2.5rem)'
  else
    assign desktop_sizes_base = '100vw'
    assign mobile_sizes_base = '100vw'
  endif

  case image_size
    when 'third'
      assign text_width_desktop = 'lg:col-span-8'
      assign desktop_sizes = 'calc(' | append: desktop_sizes_base | append: ' / 3)'

      if image_position == 'right'
        assign image_width_desktop = 'lg:col-start-9 lg:col-end-13 '
      else
        assign image_width_desktop = 'lg:col-span-4'
      endif
    when 'three_fifths'
      assign text_width_desktop = 'lg:col-span-5'
      assign desktop_sizes = 'calc((' | append: desktop_sizes_base | append: ' / 12) * 7)'

      if image_position == 'right'
        assign image_width_desktop = 'lg:col-start-6 lg:col-end-13'
      else
        assign image_width_desktop = 'lg:col-span-7'
      endif
    when 'two_thirds'
      assign text_width_desktop = 'lg:col-span-4'
      assign desktop_sizes = 'calc((' | append: desktop_sizes_base | append: ' / 12) * 8)'

      if image_position == 'right'
        assign image_width_desktop = 'lg:col-start-5 lg:col-end-13'
      else
        assign image_width_desktop = 'lg:col-span-8'
      endif
  endcase

  assign mobile_sizes = mobile_sizes_base

  assign sizes = '(min-width: 990px) ' | append: desktop_sizes | append: ', ' | append: mobile_sizes

  unless loading
    assign loading = 'lazy'

    if section.index <= 3
      assign loading = 'eager'
    endif
  endunless

  unless preload
    assign preload = false
  endunless

  # Handle text alignment for mobile vs desktop
  if mobile_text_alignment != blank
    assign mobile_text_class = mobile_text_alignment
  else
    assign mobile_text_class = text_alignment
  endif

  # Combine desktop and mobile text alignment classes
  assign combined_text_alignment = mobile_text_class | append: ' sm:' | append: text_alignment | append: ' lg:' | append: text_alignment | append: ' xl:' | append: text_alignment | append: ' 2xl:' | append: text_alignment
  # Handle mobile layout order
  if mobile_layout_order
    assign mobile_heading_order = 'order-1'
    assign mobile_image_order = 'order-2'
    assign mobile_text_order = 'order-3'
    assign mobile_button_order = 'order-4'
  else
    assign mobile_heading_order = ''
    assign mobile_image_order = ''
    assign mobile_text_order = ''
    assign mobile_button_order = ''
  endif
-%}

{%- render 'shape-defs', shape: image_shape, shape_id: section_id, index: index, blob_type: blob_type -%}

<div class="relative z-10 mx-auto max-w-site px-section">
  <div class="{% if display_on_card %}card{% endif %}">
    <div class="{% if display_on_card %}card__surface p-5 lg:p-10{% endif %} section-content relative z-10 mx-auto">
      <div class="grid grid-flow-row-dense grid-cols-1 gap-4 lg:grid-cols-12 {% if image_size == 'half' and image_position == 'right' %}reverse-flex-half{% elsif image_size == 'half' %}normal-flex-half{% endif %}">
        {%- comment -%} Mobile Layout when mobile_layout_order is enabled {%- endcomment -%}
        {%- if mobile_layout_order -%}
          {%- comment -%} Mobile: Heading first {%- endcomment -%}
          <div class="mx-auto col-span-1 lg:hidden {{ mobile_heading_order }}">
            {% if title != '' %}
              <h2 class="inline-heading-rte font-subheading {{ heading_size }} heading-style {{ settings.heading_drop_shadow_style }} break-words {{ combined_text_alignment }} custom-display-header">
                {{ title }}
              </h2>
            {% endif %}
          </div>

          {%- comment -%} Image column - responsive to both mobile order and desktop position {%- endcomment -%}
          <div
            class="image-with-text-custom-image-wrapper mx-auto lg:mx-0 {{ image_width_desktop }} {{ mobile_image_order }}"
          >
            {%- if image != blank -%}
              {%- render 'media-image',
                media: image,
                shape_id: section_id,
                shape: image_shape,
                crop: crop,
                rotate: rotate_image,
                is_card: display_on_card,
                container_id: container_id,
                disable_media_style: disable_media_style,
                loading: loading,
                preload: preload,
                sizes: sizes
              -%}
            {%- else -%}
              {%- render 'media-image-placeholder',
                shape_id: section_id,
                container_id: section_id,
                shape: image_shape,
                crop: crop,
                rotate: rotate_image,
                is_card: display_on_card,
                blob_type: blob_type,
                disable_media_style: disable_media_style
              -%}
            {%- endif -%}
          </div>

          {%- comment -%} Text content column {%- endcomment -%}
          <div class="flex items-center {{ text_width_desktop }} {% if image_size == 'half'%}min-width-on-lg-screen{% endif %}">
            <div class="w-full center-flex-column-custom">
              {%- comment -%} Desktop: Heading shown here {%- endcomment -%}
              <div class="mx-auto hidden lg:block">
                {% if title != '' %}
                  <h2 class="inline-heading-rte font-subheading {{ heading_size }} heading-style {{ settings.heading_drop_shadow_style }} break-words {{ combined_text_alignment }} custom-display-header">
                    {{ title }}
                  </h2>
                {% endif %}
              </div>

              <div class="rte max-w-2xl {{ mobile_text_order }} {{ combined_text_alignment }} lg:mt-6 mt-3 custom-body-large">
                {{ richtext }}
              </div>
              <div class="mt-5 flex items-center gap-4 custom-image-with-text-button-wrapper {{ mobile_button_order }} {{ combined_text_alignment }} lg:mt-8">
                {%- if button2_link_type == 'url' and button2_link != blank and button2_label != '' -%}
                  <div class="flex-1">
                    <a href="{{ button2_link }}" class="inline-block w-full">
                      <button class="custom-shape-button w-full">
                        <span class="custom-shape-button-text">
                          {{ button2_label }}
                        </span>
                      </button>
                    </a>
                  </div>
                {%- endif -%}
                {%- if button2_link_type == 'focus_element' and focus_element2_id != blank -%}
                  <div class="flex-1">
                    <button
                      onclick="document.getElementById('{{focus_element2_id}}')?.focus()"
                      class="w-full custom-btn custom-shape-button"
                    >
                      <span class="custom-shape-button-text">
                        {{ button2_label }}
                      </span>
                    </button>
                  </div>
                {%- endif -%}
                {%- if button_link_type == 'url' and button_link != blank and button_label != '' -%}
                  <div class="flex-1">
                    <a href="{{ button_link }}" class="inline-block w-full">
                      <button class="custom-cat push-btn custom-btn">
                        <span class="push-btn__surface custom-btn__surface custom-button-text">{{ button_label }}</span>
                      </button>
                    </a>
                  </div>
                {%- endif -%}
                {%- if button_link_type == 'focus_element' and focus_element_id != blank -%}
                  <div class="flex-1">
                    <button
                      onclick="document.getElementById('{{focus_element_id}}')?.focus()"
                      class="w-full custom-btn custom-cat push-btn"
                    >
                      <span class="push-btn__surface custom-btn__surface custom-button-text">{{ button_label }}</span>
                    </button>
                  </div>
                {%- endif -%}
              </div>
            </div>
          </div>

        {%- else -%}
          {%- comment -%} Default layout when mobile_layout_order is disabled {%- endcomment -%}
          <div class="image-with-text-custom-image-wrapper {{ image_width_desktop }}">
            {%- if image != blank -%}
              {%- render 'media-image',
                media: image,
                shape_id: section_id,
                shape: image_shape,
                crop: crop,
                rotate: rotate_image,
                is_card: display_on_card,
                container_id: container_id,
                disable_media_style: disable_media_style,
                loading: loading,
                preload: preload,
                sizes: sizes
              -%}
            {%- else -%}
              {%- render 'media-image-placeholder',
                shape_id: section_id,
                container_id: section_id,
                shape: image_shape,
                crop: crop,
                rotate: rotate_image,
                is_card: display_on_card,
                blob_type: blob_type,
                disable_media_style: disable_media_style
              -%}
            {%- endif -%}
          </div>

          <div class="flex items-center {{ text_width_desktop }} {% if image_size == 'half'%}min-width-on-lg-screen{% endif %}">
            <div class="mx-auto w-full center-flex-column-custom">
              {% if title != '' %}
                <h2 class="inline-heading-rte font-subheading {{ heading_size }} heading-style {{ settings.heading_drop_shadow_style }} break-words {{ combined_text_alignment }} custom-display-header">
                  {{ title }}
                </h2>
              {% endif %}

              <div class="rte max-w-2xl {{ combined_text_alignment }} lg:mt-6 mt-3 custom-body-large">
                {{ richtext }}
              </div>

              <div class="mt-5 flex items-center gap-4 custom-image-with-text-button-wrapper {{ combined_text_alignment }} lg:mt-8">
                {%- if button2_link_type == 'url' and button2_link != blank and button2_label != '' -%}
                  <div class="flex-1">
                    <a href="{{ button2_link }}" class="inline-block w-full">
                      <button class="custom-shape-button w-full">
                        <span class="custom-shape-button-text">
                          {{ button2_label }}
                        </span>
                      </button>
                    </a>
                  </div>
                {%- endif -%}
                {%- if button2_link_type == 'focus_element' and focus_element2_id != blank -%}
                  <div class="flex-1">
                    <button
                      onclick="document.getElementById('{{focus_element2_id}}')?.focus()"
                      class="w-full custom-btn custom-shape-button"
                    >
                      <span class="custom-shape-button-text">
                        {{ button2_label }}
                      </span>
                    </button>
                  </div>
                {%- endif -%}
                {%- if button_link_type == 'url' and button_link != blank and button_label != '' -%}
                  <div class="flex-1">
                    <a href="{{ button_link }}" class="inline-block w-full">
                      <button class="custom-cat push-btn custom-btn">
                        <span class="push-btn__surface custom-btn__surface custom-button-text">{{ button_label }}</span>
                      </button>
                    </a>
                  </div>
                {%- endif -%}
                {%- if button_link_type == 'focus_element' and focus_element_id != blank -%}
                  <div class="flex-1">
                    <button
                      onclick="document.getElementById('{{focus_element_id}}')?.focus()"
                      class="w-full custom-btn custom-cat push-btn"
                    >
                      <span class="push-btn__surface custom-btn__surface custom-button-text">{{ button_label }}</span>
                    </button>
                  </div>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>
<style>
    /* Image wrapper with shadow support */
    .image-with-text-custom-image-wrapper {
      max-width: 600px;
      max-height: 660px;
      position: relative;
    }

    .image-with-text-custom-image-wrapper .media {
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
      border-radius: 8px;
    }

    /* Button wrapper layout */
    .custom-image-with-text-button-wrapper {
      flex-direction: row;
      gap: 16px;
      width: 100%;
    }

    @media (max-width: 768px) {
      .custom-image-with-text-button-wrapper {
        flex-direction: column;
        gap: 12px;
      }
    }

    /* Ensure flex-1 buttons take equal space */
    .custom-image-with-text-button-wrapper > div {
      flex: 1;
      min-width: 0;
    }

    /* Center flex column utility */
    .center-flex-column-custom {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* Custom shape button (green button with image background) */
    .custom-shape-button {
      background-size: contain;
      background-position: center;
      background-repeat: no-repeat;
      border: none;
      cursor: pointer;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      background-image: url('{{ section.settings.button2_image | image_url: width: 800 }}');
      width: 100%;
      box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
      border-radius: 8px;
      min-height: 48px;
    }

    .custom-shape-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
    }

    .custom-shape-button-text {
      color: var(--color-ink, #201920);
      font-family: var(--font-body, 'Banter Grotesk', sans-serif);
      font-size: 16px;
      font-weight: 400;
      padding: {{ section.settings.button2_padding_topbottom | default: 20 }}px 24px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    @media (min-width: 769px) {
      .custom-shape-button-text {
        font-size: 18px;
      }
    }

    /* Standard button styling - push-btn overrides */
    .custom-image-with-text-button-wrapper .custom-cat.push-btn {
      position: relative;
      width: 100%;
      min-height: 48px;
    }

    .custom-image-with-text-button-wrapper .push-btn__surface {
      display: block;
      width: 100%;
      box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
      border-radius: 8px;
      transition: all 0.3s ease;
    }

    .custom-image-with-text-button-wrapper .push-btn:hover .push-btn__surface {
      transform: translateY(-2px);
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
    }

    /* Responsive font sizing for buttons */
    @media (max-width: 768px) {
      .custom-image-with-text-button-wrapper .custom-button-text {
        font-size: 16px !important;
      }
    }

    @media (min-width: 769px) {
      .custom-image-with-text-button-wrapper .custom-button-text {
        font-size: 18px !important;
      }
    }

    @media (min-width: 1024px) {
      .normal-flex-half {
        display: flex;
        justify-content: center;
        gap: 1.5rem; /* 24px - lg:gap-6 */
      }

      .min-width-on-lg-screen {
        min-width: 460px;
      }

      .reverse-flex-half {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        flex-direction: row-reverse;
      }
    }

    @media (min-width: 1280px) {
      .normal-flex-half,
      .reverse-flex-half {
        gap: 2rem; /* 32px - xl:gap-8 */
      }
    }
</style>
