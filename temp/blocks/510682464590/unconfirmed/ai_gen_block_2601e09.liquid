<kaadu-market-chart-{{ ai_gen_id }}
  class="ai-market-chart-{{ ai_gen_id }}"
  data-kaadu-price="{{ block.settings.kaadu_price }}"
  data-market-min="{{ block.settings.market_min }}"
  data-market-max="{{ block.settings.market_max }}"
  data-price-min="{{ block.settings.price_min }}"
  data-price-max="{{ block.settings.price_max }}"
  data-sample-ms="{{ block.settings.sample_ms }}"
  data-scroll-speed="{{ block.settings.scroll_speed }}"
  data-kaadu-color="{{ block.settings.kaadu_color }}"
  data-market-color="{{ block.settings.market_color }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h2 class="ai-market-chart-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="ai-market-chart-wrapper-{{ ai_gen_id }}">
    <div class="ai-market-chart-stage-{{ ai_gen_id }}" data-stage>
      <canvas data-canvas></canvas>
      <div class="ai-market-chart-badge-{{ ai_gen_id }}" data-badge>RPS 60</div>
    </div>

    <div class="ai-market-chart-tags-{{ ai_gen_id }}">
      <span data-market-tag data-label="{{ block.settings.market_label }}" style="color: {{ block.settings.market_color }};">{{ block.settings.market_label }}: 40</span>
      <span data-kaadu-tag data-label="{{ block.settings.kaadu_label }}" style="color: {{ block.settings.kaadu_color }};">{{ block.settings.kaadu_label }}: 60</span>
    </div>

    <div class="ai-market-chart-legend-{{ ai_gen_id }}">
      <div class="ai-market-chart-leg-{{ ai_gen_id }}">
        <span class="ai-market-chart-dot-{{ ai_gen_id }}" style="background: {{ block.settings.market_color }};"></span>
        {{ block.settings.market_label }}
      </div>
      <div class="ai-market-chart-leg-{{ ai_gen_id }}">
        <span class="ai-market-chart-dot-{{ ai_gen_id }}" style="background: {{ block.settings.kaadu_color }};"></span>
        {{ block.settings.kaadu_label }}
      </div>
    </div>
  </div>
</kaadu-market-chart-{{ ai_gen_id }}>

<script>
(function() {
  class KaaduMarketChart{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.__kwInitialized = false;
    }

    connectedCallback() {
      if (this.__kwInitialized) return;
      this.__kwInitialized = true;

      var stage = this.querySelector('[data-stage]');
      var canvas = this.querySelector('[data-canvas]');
      if (!stage || !canvas) return;
      var ctx = canvas.getContext('2d');
      var badge = this.querySelector('[data-badge]');
      var marketTag = this.querySelector('[data-market-tag]');
      var kaaduTag = this.querySelector('[data-kaadu-tag]');

      var KAADU_PRICE = parseFloat(this.dataset.kaaduPrice) || 60;
      var MARKET_MIN = parseFloat(this.dataset.marketMin) || 21;
      var MARKET_MAX = parseFloat(this.dataset.marketMax) || 58;
      var PRICE_MIN = parseFloat(this.dataset.priceMin) || 10;
      var PRICE_MAX = parseFloat(this.dataset.priceMax) || 70;
      var SAMPLE_MS = parseFloat(this.dataset.sampleMs) || 180;
      var PX_PER_SEC = parseFloat(this.dataset.scrollSpeed) || 44;
      var KAADU_COLOR = this.dataset.kaaduColor || '#b6ff4a';
      var MARKET_COLOR = this.dataset.marketColor || '#AE0000';

      var kaaduImg = new Image();
      var kaaduReady = false;
      kaaduImg.onload = function () { kaaduReady = true; };
      kaaduImg.src =
        'data:image/svg+xml;utf8,' +
        encodeURIComponent(
          '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="' + KAADU_COLOR + '"/></svg>'
        );

      var marketImg = new Image();
      var marketReady = false;
      marketImg.onload = function () { marketReady = true; };
      marketImg.src =
        'data:image/svg+xml;utf8,' +
        encodeURIComponent(
          '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="' + MARKET_COLOR + '"/></svg>'
        );

      var dpr = window.devicePixelRatio || 1;
      var w = 0, h = 0;

      function resize() {
        var rect = stage.getBoundingClientRect();
        w = rect.width;
        h = rect.height;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        ctx.scale(dpr, dpr);
      }

      resize();
      window.addEventListener('resize', resize);

      var kaaduHistory = [];
      var marketHistory = [];
      var scrollX = 0;
      var lastSample = Date.now();
      var lastFrame = Date.now();
      var fps = 0;
      var fpsFrames = 0;
      var fpsTime = 0;

      function randomInRange(min, max) {
        return Math.random() * (max - min) + min;
      }

      function mapPrice(price) {
        return h - ((price - PRICE_MIN) / (PRICE_MAX - PRICE_MIN)) * h;
      }

      function samplePrices() {
        var now = Date.now();
        if (now - lastSample >= SAMPLE_MS) {
          lastSample = now;
          var marketPrice = randomInRange(MARKET_MIN, MARKET_MAX);
          kaaduHistory.push({ x: scrollX, y: mapPrice(KAADU_PRICE) });
          marketHistory.push({ x: scrollX, y: mapPrice(marketPrice) });

          if (marketTag) {
            var marketLabel = marketTag.getAttribute('data-label') || 'Marktpreis';
            marketTag.textContent = marketLabel + ': ' + marketPrice.toFixed(0);
          }
          if (kaaduTag) {
            var kaaduLabel = kaaduTag.getAttribute('data-label') || 'Kaadu Preis';
            kaaduTag.textContent = kaaduLabel + ': ' + KAADU_PRICE.toFixed(0);
          }
        }
      }

      function drawLine(history, color, img, ready) {
        if (history.length < 2) return;
        ctx.strokeStyle = color;
        ctx.lineWidth = 2;
        ctx.beginPath();
        for (var i = 0; i < history.length; i++) {
          var pt = history[i];
          var x = w - (scrollX - pt.x);
          if (i === 0) {
            ctx.moveTo(x, pt.y);
          } else {
            ctx.lineTo(x, pt.y);
          }
        }
        ctx.stroke();

        if (ready && history.length > 0) {
          var last = history[history.length - 1];
          var x = w - (scrollX - last.x);
          ctx.drawImage(img, x - 12, last.y - 12, 24, 24);
        }
      }

      function draw() {
        ctx.clearRect(0, 0, w, h);
        drawLine(marketHistory, MARKET_COLOR, marketImg, marketReady);
        drawLine(kaaduHistory, KAADU_COLOR, kaaduImg, kaaduReady);
      }

      function loop() {
        var now = Date.now();
        var dt = (now - lastFrame) / 1000;
        lastFrame = now;

        scrollX += PX_PER_SEC * dt;

        kaaduHistory = kaaduHistory.filter(function (pt) {
          return w - (scrollX - pt.x) > -50;
        });
        marketHistory = marketHistory.filter(function (pt) {
          return w - (scrollX - pt.x) > -50;
        });

        samplePrices();
        draw();

        fpsFrames++;
        fpsTime += dt;
        if (fpsTime >= 1) {
          fps = Math.round(fpsFrames / fpsTime);
          if (badge) badge.textContent = 'RPS ' + fps;
          fpsFrames = 0;
          fpsTime = 0;
        }

        requestAnimationFrame(loop);
      }

      loop();
    }
  }

  customElements.define('kaadu-market-chart-{{ ai_gen_id }}', KaaduMarketChart{{ ai_gen_id }});
})();
</script>

