{% doc %}
  @prompt
    <!DOCTYPE html>
    <html lang="de">
    <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
    <title>Kaadu Market Chart</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html, body {
        margin: 0;
        padding: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: #ffffff;
        color: #1a1a1a;
      }
      body {
        padding: 16px;
        min-height: 100vh;
      }
    
      .kaadu-market-section {
        width: 100%;
        max-width: 900px;
        margin: 0 auto;
        padding: 16px;
        background: transparent;
      }
      .kaadu-market-heading {
        text-align: center;
        margin: 0 0 16px;
        font-size: clamp(18px, 4vw, 22px);
        font-weight: 500;
      }
      .kaadu-market-section .kw {
        position: relative;
        width: 100%;
        background: transparent;
        padding: 6px 0;
      }
      .kaadu-market-section .kw-stage {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        min-height: 180px;
        max-height: 520px;
        overflow: hidden;
      }
      .kaadu-market-section .kw-stage canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        display: block;
      }
      .kaadu-market-section .kw-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        font-size: clamp(11px, 2.5vw, 13px);
        font-weight: 500;
        letter-spacing: 0.5px;
        z-index: 5;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        background: rgba(128, 128, 128, 0.15);
        padding: 3px 8px;
        border-radius: 4px;
      }
      .kaadu-market-section .kw-tags {
        display: flex;
        justify-content: space-between;
        margin-top: 10px;
        font-size: clamp(11px, 2.5vw, 13px);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        flex-wrap: wrap;
        gap: 8px;
      }
      .kaadu-market-section .kw-legend {
        display: flex;
        gap: clamp(12px, 4vw, 22px);
        justify-content: center;
        margin-top: 10px;
        flex-wrap: wrap;
      }
      .kaadu-market-section .kw-leg {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: clamp(11px, 2.5vw, 13px);
      }
      .kaadu-market-section .kw-dot {
        width: clamp(10px, 2.5vw, 12px);
        height: clamp(10px, 2.5vw, 12px);
        border-radius: 50%;
        flex-shrink: 0;
      }
    
      /* Small phones: taller aspect so the chart still has room */
      @media (max-width: 480px) {
        body { padding: 8px; }
        .kaadu-market-section { padding: 8px; }
        .kaadu-market-section .kw-stage {
          aspect-ratio: 4 / 3;
          min-height: 220px;
        }
      }
      /* Landscape phones */
      @media (max-width: 900px) and (orientation: landscape) {
        .kaadu-market-section .kw-stage {
          aspect-ratio: 16 / 9;
          min-height: 180px;
        }
      }
    </style>
    </head>
