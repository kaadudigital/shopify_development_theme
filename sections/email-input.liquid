<!-- Section HTML -->
<div class="email-signup-section">
  <div class="email-signup-container">
    {% if section.settings.heading != blank %}
      <h2 class="email-signup-heading h2">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <form method="post" action="/contact#contact_form" accept-charset="UTF-8" class="contact-form email-signup-form" id="contact_form">
      <input type="hidden" name="form_type" value="customer">
      <input type="hidden" name="contact[tags]" value="waitlist">
      <input type="hidden" name="utf8" value="✓">

      <div class="email-signup-wrapper">
        <input
          type="email"
          name="contact[email]"
          placeholder="{{ section.settings.placeholder_text }}"
          id="Email"
          class="email-signup-input body"
          required
        />

        <button
          type="submit"
          class="email-signup-submit"
          aria-label="{{ section.settings.button_text | default: 'Submit' | escape }}"
        >
          <svg class="email-signup-submit__burst" viewBox="0 0 78 73" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M77.4617 33.3842C77.717 36.9325 67.6423 39.4471 66.7504 42.7188C65.8352 46.0756 73.2364 53.3107 71.2989 56.1732C69.3735 59.0178 59.8399 54.8969 57.0897 57.0507C54.4081 59.1509 56.1888 69.3978 52.896 70.6516C49.7463 71.8509 44.2411 63.0567 40.685 63.314C37.1289 63.5714 32.9397 73.0673 29.6509 72.334C26.2127 71.5673 26.5081 61.1701 23.5536 59.4779C20.5236 57.7424 11.6786 63.1934 9.36597 60.6555C7.03879 58.1017 13.3276 49.8758 11.9414 46.6856C10.5903 43.5763 0.260099 42.5384 0.00480744 38.9902C-0.250484 35.4419 9.82414 32.9272 10.7161 29.6555C11.6312 26.2988 4.23007 19.0637 6.16757 16.2012C8.09298 13.3566 17.6266 17.4775 20.3768 15.3236C23.0584 13.2235 21.2777 2.97659 24.5705 1.72278C27.7202 0.523441 33.2254 9.31768 36.7815 9.06031C40.3376 8.80294 44.5268 -0.69294 47.8156 0.0404044C51.2538 0.807061 50.9584 11.2042 53.9129 12.8965C56.9429 14.632 65.7878 9.18094 68.1005 11.7188C70.4277 14.2726 64.1389 22.4985 65.5251 25.6887C66.8762 28.7981 77.2064 29.836 77.4617 33.3842Z"
              fill="var(--color-lime)"
            />
            <path
              d="M 24 36.5 L 50 36.5 M 42 28 L 53 36.5 L 42 45"
              stroke="var(--color-violet)"
              stroke-width="5.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              fill="none"
            />
          </svg>
        </button>
      </div>

      <div class="email-signup-message caption" hidden></div>
    </form>

    {% if section.settings.subtitle != blank %}
      <p class="email-signup-subtitle caption">
        {{ section.settings.subtitle }}
      </p>
    {% endif %}
  </div>
</div>


{%- style -%}
  #shopify-section-{{ section.id }} {
    --es-bg: {{ section.settings.background_color }};
    --es-heading: {{ section.settings.heading_color }};
    --es-subtitle: {{ section.settings.subtitle_color }};
    --es-input-bg: {{ section.settings.input_background }};
    --es-input-text: {{ section.settings.input_text_color }};
    --es-input-border: {{ section.settings.input_border_color }};
    --es-input-focus: {{ section.settings.input_focus_border }};
    --es-placeholder: {{ section.settings.placeholder_color }};
  }

  #shopify-section-{{ section.id }} .email-signup-section {
    background-color: var(--es-bg);
    padding: {{ section.settings.padding_top }}px var(--space-4) {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .email-signup-container {
    max-width: {{ section.settings.container_width }}px;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .email-signup-heading {
    color: var(--es-heading);
    text-align: center;
    margin: 0 0 var(--space-8);
  }

  #shopify-section-{{ section.id }} .email-signup-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    max-width: 600px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .email-signup-input {
    flex: 1 1 auto;
    min-width: 0;
    height: 64px;
    padding: var(--space-4) var(--space-8);
    background-color: var(--es-input-bg);
    color: var(--es-input-text);
    border: 2px solid var(--es-input-border);
    border-radius: var(--radius-btn);
    outline: none;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  #shopify-section-{{ section.id }} .email-signup-input::placeholder {
    color: var(--es-placeholder);
  }

  #shopify-section-{{ section.id }} .email-signup-input:focus-visible {
    border-color: var(--es-input-focus);
    box-shadow: 0 0 0 3px {{ section.settings.input_focus_border }}33;
  }

  #shopify-section-{{ section.id }} .email-signup-submit {
    flex: 0 0 auto;
    width: 80px;
    aspect-ratio: 78 / 73;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
    transition: transform 0.15s ease;
  }

  #shopify-section-{{ section.id }} .email-signup-submit:hover {
    transform: translateY(-2px) scale(1.04);
  }

  #shopify-section-{{ section.id }} .email-signup-submit:active {
    transform: translateY(0) scale(1);
  }

  #shopify-section-{{ section.id }} .email-signup-submit:focus-visible {
    outline: 3px solid var(--color-cream);
    outline-offset: 4px;
    border-radius: 50%;
  }

  #shopify-section-{{ section.id }} .email-signup-submit__burst {
    width: 90%;
    height: 90%;
    display: block;
    filter: drop-shadow(var(--shadow-sm));
  }

  #shopify-section-{{ section.id }} .email-signup-subtitle {
    color: var(--es-subtitle);
    text-align: center;
    margin: var(--space-6) 0 0;
  }

  #shopify-section-{{ section.id }} .email-signup-message {
    text-align: center;
    margin-top: var(--space-4);
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .email-signup-section {
      padding-top: calc({{ section.settings.padding_top }}px / 2);
      padding-bottom: calc({{ section.settings.padding_bottom }}px / 2);
    }
    #shopify-section-{{ section.id }} .email-signup-heading {
      margin-bottom: var(--space-6);
    }
    #shopify-section-{{ section.id }} .email-signup-input {
      height: 56px;
      padding: var(--space-2) var(--space-4);
      font-size: 14px !important;
      line-height: 20px !important;
      max-width: 220px;
    }
    #shopify-section-{{ section.id }} .email-signup-submit {
      width: 56px;
    }
    #shopify-section-{{ section.id }} .email-signup-wrapper {
      gap: var(--space-4);
      max-width: 340px;
    }
    #shopify-section-{{ section.id }} .email-signup-submit__burst {
    width: 105%;
    height: 105%;
  }
  }
{%- endstyle -%}

<script>
  // Show success message after form submission
  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.get('customer_posted') === 'true') {
    const pathParts = window.location.pathname.split('/');
    pathParts[pathParts.length - 1] = 'waitlist-success';
    window.location.replace(pathParts.join('/'));
  }
</script>

  {%- liquid
    for block in section.blocks
      case block.type
        when 'background_shape'
          render 'block-background-shape', block: block
        when 'background_pattern'
          render 'block-background-pattern', block: block, scheme: section.settings.color_scheme
      endcase
    endfor
  -%}

{%- liquid
  assign stickers = section.blocks | where: 'type', 'sticker'
  assign shape_dividers = section.blocks | where: 'type', 'shape_divider'
  for sticker in stickers
    render 'block-sticker', block: sticker
  endfor
  for shape_divider in shape_dividers
    render 'block-shape-divider', block: shape_divider
  endfor
-%}

