    },
    {
      "type": "range",
      "id": "button_padding_tb",
      "label": "Button Padding Top/Bottom",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_lr",
      "label": "Button Padding Left/Right",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button Border Radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "button_margin_top",
      "label": "Button Margin Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "button_alignment",
      "label": "Button Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Colour Scheme"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme1",
      "label": "Colour Scheme"
    },
    {
      "type": "checkbox",
      "id": "use_gradient_background",
      "label": "Use Gradient Background"
    }
  ],
  "blocks": [
    {
      "type": "richtext",
      "name": "Richtext Block",
      "limit": 6,
      "settings": [
        {
          "type": "header",
          "content": "Heading"
        },
        {
          "type": "richtext",
          "id": "heading",
          "label": "Heading",
        },
        {
          "type": "range",
          "id": "heading_font_size",
          "label": "Heading Font Size",
          "min": 10,
          "max": 60,
          "step": 1,
          "unit": "px",
          "default": 18
        },
        {
          "type": "select",
          "id": "heading_font_weight",
          "label": "Heading Font Weight",
          "options": [
            { "value": "400", "label": "Regular" },
            { "value": "600", "label": "Semi Bold" },
            { "value": "700", "label": "Bold" },
            { "value": "800", "label": "Extra Bold" },
            { "value": "900", "label": "Black" }
          ],
          "default": "700"
        },
        {
          "type": "text",
          "id": "heading_font_family",
          "label": "Heading Font Family",
          "default": "inherit",
          "info": "Use 'inherit' to follow theme font, or enter a custom font name e.g. 'fagies, sans-serif'."
        },
        {
          "type": "color",
          "id": "heading_color",
          "label": "Heading Colour",
          "default": "#AE0000"
        },
        {
          "type": "header",
          "content": "Body Text"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Body Text",
          "default": "<p>Use this text to describe a feature or benefit.</p>"
        },
        {
          "type": "range",
          "id": "text_font_size",
          "label": "Body Font Size",
          "min": 10,
          "max": 36,
          "step": 1,
          "unit": "px",
          "default": 14
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Body Text Colour",
          "default": "#333333"
        },
        {
          "type": "header",
          "content": "Alignment"
        },
        {
          "type": "select",
          "id": "text_alignment",
          "label": "Text Alignment",
          "options": [
            { "value": "left",   "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right",  "label": "Right" }
          ],
          "default": "left",
