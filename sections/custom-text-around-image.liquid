      "info": "Enter ID without #. Used only when action is 'Focus Element by ID'."
    },
    {
      "type": "image_picker",
      "id": "button_image",
      "label": "Button Background Image",
      "info": "Replaces solid colour if set (e.g. a shaped PNG)."
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background Colour",
      "default": "#7CFC00"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Colour",
      "default": "#AE0000"
    },
    {
      "type": "text",
      "id": "button_font_family",
      "label": "Button Font Family",
      "default": "fagies, sans-serif"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Button Font Size",
      "min": 10,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "button_font_weight",
      "label": "Button Font Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
