{%- comment -%}
  Custom section: Centered image with 6 richtext blocks in a 2-col × 3-row grid.
  The image sits below the text blocks via z-index layering.
  All 6 blocks are full richtext with individually configurable text alignment.
{%- endcomment -%}

<section
  class="custom-img-text-section relative overflow-hidden text-scheme-text {% if section.settings.use_gradient_background %}bg-scheme-gradient{% endif %}"
  data-color-scheme="{{ section.settings.color_scheme }}"
  id="custom-img-text-{{ section.id }}"
  style="background-color: {{ section.settings.section_bg_color }}; padding-left: 24px; padding-right: 24px; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; --content-height-desktop: {{ section.settings.content_height_desktop }}px; --content-height-mobile: {{ section.settings.content_height_mobile }}px;"
>

  {%- comment -%} ── Section headings ── {%- endcomment -%}
  {% if section.settings.title != blank %}
    <h2
      class="inline-heading-rte font-heading heading-standard heading-style break-words custom-display-header {{ settings.heading_drop_shadow_style }}"
      style="display:block; text-align: {{ section.settings.heading_alignment }}; color: {{ section.settings.heading_color }}; font-size: {{ section.settings.heading_size }}px; margin-bottom: 0;"
    >
      {{ section.settings.title }}
    </h2>
  {% endif %}
  {% if section.settings.title2 != blank %}
    <h2
      class="inline-heading-rte font-heading heading-standard heading-style break-words  custom-display-header {{ settings.heading_drop_shadow_style }}"
      style="display:block; text-align: {{ section.settings.heading_alignment }}; color: {{ section.settings.heading_color }}; font-size: {{ section.settings.heading_size }}px; margin-bottom: 0;"
    >
      {{ section.settings.title2 }}
    </h2>
  {% endif %}
  {% if section.settings.title3 != blank %}
    <h2
      class="inline-heading-rte font-heading heading-standard heading-style break-words custom-display-header {{ settings.heading_drop_shadow_style }}"
      style="display:block; text-align: {{ section.settings.heading_alignment }}; color: {{ section.settings.heading_color }}; font-size: {{ section.settings.heading_size }}px;"
    >
      {{ section.settings.title3 }}
    </h2>
  {% endif %}

  {% if section.settings.subheading != blank %}
    <div
      class="inline-rte mx-auto custom-body-xlarge"
      style="text-align: {{ section.settings.heading_alignment }}; color: {{ section.settings.subheading_color }}; font-size: {{ section.settings.subheading_size }}px; margin-top: {{ section.settings.subheading_margin_top }}px; max-width: {{ section.settings.subheading_max_width }}px;"
    >
      {{ section.settings.subheading }}
    </div>
  {% endif %}

  {%- comment -%}
    ── Content area ──
    The image is absolutely centred at z-index 0.
    The 2-col × 3-row grid sits at z-index 1 above it.
  {%- endcomment -%}
  <div
    class="custom-img-text-section__content"
    style="margin-top: {{ section.settings.content_margin_top }}px;"
  >
    {%- comment -%} Spacer that gives the content area its explicit height {%- endcomment -%}

    {%- comment -%} Centered image — z-index 0, behind text {%- endcomment -%}
    {% if section.settings.main_image != blank %}
      <div class="custom-img-text-section__image-wrap">
        <img
          height=""
          width=""
          src="{{ section.settings.main_image | img_url: 'master' }}"
          alt="{{ section.settings.main_image.alt | escape }}"
          class="custom-img-text-section__image"
          style="
            {% if section.settings.image_dimension_type == 'width' %}
              width: {{ section.settings.image_width }}px;
              height: auto;
            {% else %}
              height: {{ section.settings.image_height }}px;
              width: auto;
            {% endif %}
            max-width: 100%;
          "
          loading="lazy"
        >
      </div>
    {% endif %}

    {%- comment -%} 2-col × 3-row text grid — z-index 1, above image {%- endcomment -%}
    <div
      class="custom-img-text-section__grid"
      style="gap: {{ section.settings.grid_gap }}px; max-width: {{ section.settings.grid_max_width }}px;"
    >
      {% for block in section.blocks %}
        {% if block.type == 'richtext' %}
          {%- liquid
            assign offset_desktop_val = block.settings.offset_desktop_px
            assign offset_mobile_val  = block.settings.offset_mobile_px
            if block.settings.offset_desktop_dir == 'left'
              assign offset_desktop_val = offset_desktop_val | times: -1
            endif
            if block.settings.offset_mobile_dir == 'left'
              assign offset_mobile_val = offset_mobile_val | times: -1
            endif
          -%}
          <div
            class="custom-img-text-section__block"
            {{ block.shopify_attributes }}
            style="
              text-align: {{ block.settings.text_alignment }};
              --block-offset-desktop: {{ offset_desktop_val }}px;
              --block-offset-mobile: {{ offset_mobile_val }}px;
              {% if block.settings.block_bg_color != blank %}
                background-color: {{ block.settings.block_bg_color }};
                padding: {{ block.settings.block_padding }}px;
                border-radius: {{ block.settings.block_border_radius }}px;
              {% endif %}
            "
          >
            {% if block.settings.heading != blank %}
              <p
                style="
                  color: {{ block.settings.heading_color }};
                  font-size: {{ block.settings.heading_font_size }}px;
                  font-weight: {{ block.settings.heading_font_weight }};
                  font-family: {{ block.settings.heading_font_family }};
                  line-height: 1.2;
                  margin: 0 0 6px 0;
                "
              >
                {{ block.settings.heading }}
              </p>
            {% endif %}

            {% if block.settings.text != blank %}
              <div
                style="
                  color: {{ block.settings.text_color }};
                  font-size: {{ block.settings.text_font_size }}px;
                  line-height: 1.5;
                "
              >
                {{ block.settings.text }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>

  {%- comment -%} ── CTA Button (below content grid) ── {%- endcomment -%}
  {%- if section.settings.button_label != blank -%}
    {%- if section.settings.button_link_type == 'url' and section.settings.button_link != blank -%}
      <div
        class="custom-img-text-section__btn-wrap"
        style="justify-content: {{ section.settings.button_alignment }}; margin-top: {{ section.settings.button_margin_top }}px;"
      >
        <a href="{{ section.settings.button_link }}">
          <button
            class="custom-img-text-section__btn"
            style="
              {% if section.settings.button_image != blank %}
                background-image: url('{{ section.settings.button_image | img_url: 'master' }}');
                background-color: transparent;
              {% else %}
                background-color: {{ section.settings.button_bg_color }};
                border-radius: {{ section.settings.button_border_radius }}px;
              {% endif %}
              background-size: contain;
              background-position: center;
              background-repeat: no-repeat;
            "
          >
            <span
              class="custom-img-text-section__btn-text"
              style="
                color: {{ section.settings.button_text_color }};
                font-family: {{ section.settings.button_font_family }};
                font-size: {{ section.settings.button_font_size }}px;
                font-weight: {{ section.settings.button_font_weight }};
                padding: {{ section.settings.button_padding_tb }}px {{ section.settings.button_padding_lr }}px;
              "
            >
              {{ section.settings.button_label }}
            </span>
          </button>
        </a>
      </div>
    {%- elsif section.settings.button_link_type == 'focus_element' and section.settings.focus_element_id != blank -%}
      <div
        class="custom-img-text-section__btn-wrap"
        style="justify-content: {{ section.settings.button_alignment }}; margin-top: {{ section.settings.button_margin_top }}px;"
      >
        <button
          class="custom-img-text-section__btn"
          onclick="document.getElementById('{{ section.settings.focus_element_id }}')?.focus()"
          style="
            {% if section.settings.button_image != blank %}
              background-image: url('{{ section.settings.button_image | img_url: 'master' }}');
              background-color: transparent;
            {% else %}
              background-color: {{ section.settings.button_bg_color }};
              border-radius: {{ section.settings.button_border_radius }}px;
            {% endif %}
            background-size: contain;
            background-position: center;
            background-repeat: no-repeat;
          "
        >
          <span
            class="custom-img-text-section__btn-text"
            style="
              color: {{ section.settings.button_text_color }};
              font-family: {{ section.settings.button_font_family }};
              font-size: {{ section.settings.button_font_size }}px;
              font-weight: {{ section.settings.button_font_weight }};
              padding: {{ section.settings.button_padding_tb }}px {{ section.settings.button_padding_lr }}px;
            "
          >
            {{ section.settings.button_label }}
          </span>
        </button>
      </div>
    {%- endif -%}
  {%- endif -%}

  {%- comment -%} ── Background shapes & patterns ── {%- endcomment -%}
  {%- liquid
    for block in section.blocks
      case block.type
        when 'background_shape'
          render 'block-background-shape', block: block
        when 'background_pattern'
          render 'block-background-pattern', block: block, scheme: section.settings.color_scheme
      endcase
    endfor
  -%}

</section>

{%- liquid
  assign stickers = section.blocks | where: 'type', 'sticker'
  assign shape_dividers = section.blocks | where: 'type', 'shape_divider'
  for sticker in stickers
    render 'block-sticker', block: sticker
  endfor
  for shape_divider in shape_dividers
    render 'block-shape-divider', block: shape_divider
  endfor
-%}

<style>
  /* ────────────────────────────────────────────────
     Content wrapper
     - starts after the subheading (normal flow)
     - explicit desktop height so image + grid share
       the same measured space
  ──────────────────────────────────────────────── */
  #custom-img-text-{{ section.id }} .custom-img-text-section__content {
    position: relative;
    width: 100%;
    height: var(--content-height-desktop);
    /* centre children for the absolute image */
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Image: centred absolutely inside the content box,
       z-index 0 — behind the text grid ── */
  #custom-img-text-{{ section.id }} .custom-img-text-section__image-wrap {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 0;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #custom-img-text-{{ section.id }} .custom-img-text-section__image {
    display: block;
  }

  /* ── 2-column × 3-row grid
       z-index 1 — above the image ── */
  #custom-img-text-{{ section.id }} .custom-img-text-section__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto auto;
    width: 100%;
    height: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  #custom-img-text-{{ section.id }} .custom-img-text-section__block {
    display: flex;
    flex-direction: column;
    justify-content: center;
    transform: translateX(var(--block-offset-desktop, 0px));
    transition: transform 0s;
  }

  /* ── Button ── */
  #custom-img-text-{{ section.id }} .custom-img-text-section__btn-wrap {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
  }

  #custom-img-text-{{ section.id }} .custom-img-text-section__btn {
    border: none;
    cursor: pointer;
    transition: transform 0.3s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #custom-img-text-{{ section.id }} .custom-img-text-section__btn:hover {

  }

  /* ── Mobile: single column, centered text, mobile height & mobile offsets ── */
  @media (max-width: 600px) {
    #custom-img-text-{{ section.id }} .custom-img-text-section__content {
      height: var(--content-height-mobile);
    }

    #custom-img-text-{{ section.id }} .custom-img-text-section__grid {
      grid-template-columns: 1fr;
    }

    /* Force all text blocks to center-align on mobile */
    #custom-img-text-{{ section.id }} .custom-img-text-section__block {
      text-align: center !important;
      transform: translateX(var(--block-offset-mobile, 0px));
    }
  }
</style>

{% schema %}
{
  "name": "Custom text around image",
  "settings": [
    {
      "type": "header",
      "content": "Section Headings"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading Line 1",
      "default": "GEFRIERGETROCKNETER"
    },
    {
      "type": "inline_richtext",
      "id": "title2",
      "label": "Heading Line 2",
      "default": "GENUSS"
    },
    {
      "type": "inline_richtext",
      "id": "title3",
      "label": "Heading Line 3"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Colour",
      "default": "#AE0000"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 16,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Ohne Stress, ohne Masse – dafür mit 100 % Fokus auf Qualität."
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Colour",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading Font Size",
      "min": 10,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "subheading_margin_top",
      "label": "Subheading Margin Top",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "subheading_max_width",
      "label": "Subheading Max Width",
      "min": 200,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 600
    },
    {
      "type": "header",
      "content": "Center Image"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_dimension_type",
      "label": "Control Image Size By",
      "options": [
        { "value": "width", "label": "Width (height scales automatically)" },
        { "value": "height", "label": "Height (width scales automatically)" }
      ],
      "default": "width"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image Width",
      "min": 200,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 500,
      "info": "Active when 'Control Image Size By' is set to Width"
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image Height",
      "min": 100,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "default": 500,
      "info": "Active when 'Control Image Size By' is set to Height"
    },
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background Colour",
      "default": "#FFB3D9"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "content_margin_top",
      "label": "Space Between Subheading and Content",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "content_height_desktop",
      "label": "Content Area Height — Desktop",
      "min": 200,
      "max": 1200,
      "step": 10,
      "unit": "px",
      "default": 600,
      "info": "Height of the image + text grid area on screens wider than 600 px."
    },
    {
      "type": "range",
      "id": "content_height_mobile",
      "label": "Content Area Height — Mobile",
      "min": 200,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 420,
      "info": "Height of the image + text grid area on screens 600 px wide and below."
