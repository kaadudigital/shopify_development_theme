{%- liquid
  assign video = section.settings.video

  if video and section.settings.aspect_ratio == 'natural'
    assign ratio = 1.0000 | divided_by: video.aspect_ratio | times: 100.0000
  else
    if section.settings.aspect_ratio == 'natural'
      assign ratio = '16:9' | split: ':'
    else
      assign ratio = section.settings.aspect_ratio | split: ':'
    endif

    assign ratio = ratio[1] | plus: 0.000 | divided_by: ratio[0] | plus: 0.000 | times: 100.000
  endif

  assign video_modal_id = 'video-modal-' | append: section.id | replace: '_', '-' | handleize

  assign play_btn_bg    = section.settings.play_button_background_color
  assign play_btn_color = section.settings.play_button_icon_color

  assign frame_shape = section.settings.video_frame_shape
-%}

<section
  class="relative grid bg-scheme-background text-scheme-text{% if section.settings.use_gradient_background %} bg-scheme-gradient{% endif %} overflow-hidden"
  data-color-scheme="{{ section.settings.color_scheme }}"
>
  <div class="section-content{% if section.settings.style == 'inset' %} py-section-vertical-spacing{% endif %}">
    {% if section.settings.title != '' %}
      <h2 class="inline-heading-rte font-heading heading-standard heading-style break-words custom-display-header text-center {{ settings.heading_drop_shadow_style }}{% if section.settings.style == 'full' %} pt-section-vertical-spacing{% endif %}">
        {{ section.settings.title }}
      </h2>
    {% endif %}

    <div class="mx-auto w-full{% if section.settings.style == 'inset' %} max-w-site px-section{% endif %}{% if section.settings.title != '' %}  section-content-top-margin{% endif %}">
      {%- comment -%} Inline SVG clipPath definitions for custom shapes {%- endcomment -%}
      {%- if frame_shape == 'website_shape_star'
          or frame_shape == 'website_shape_bun'
          or frame_shape == 'website_shape_cloud'
          or frame_shape == 'website_shape_frame'
          or frame_shape == 'website_shape_pancake' -%}
        <svg width="0" height="0" style="position:absolute">
          <defs>
            {%- if frame_shape == 'website_shape_star' -%}
              <clipPath id="clip-{{ section.id }}" clipPathUnits="objectBoundingBox">
                <path transform="scale(0.000667)" d="M1423.3,750c0,61.7-177.4,92.6-196.9,148-20,56.9,99,191.3,61.9,238.4-36.8,46.8-196.6-36.4-246.8-2.6-49,33-30.9,212.4-89.5,230-56,16.8-140.2-142.2-202.1-142.2s-146.1,159-202.1,142.2c-58.5-17.6-40.5-197-89.5-230-50.2-33.8-210,49.4-246.8,2.6-37.1-47.1,81.9-181.5,61.9-238.4-19.5-55.5-196.9-86.3-196.9-148s177.4-92.6,196.9-148c20-56.9-99-191.3-61.9-238.4,36.8-46.8,196.6,36.4,246.8,2.6,49-33,30.9-212.4,89.5-230,56-16.8,140.2,142.2,202.1,142.2s146.1-159,202.1-142.2c58.5,17.6,40.5,197,89.5,230,50.2,33.8,210-49.4,246.8-2.6,37.1,47.1-81.9,181.5-61.9,238.4,19.5,55.5,196.9,86.3,196.9,148h0Z"/>
              </clipPath>
            {%- elsif frame_shape == 'website_shape_bun' -%}
              <clipPath id="clip-{{ section.id }}" clipPathUnits="objectBoundingBox">
                <path transform="scale(0.000667)" d="M1177.7,343c-83.6,0-158.3,56.5-208.2,145.4-49.9-88.9-124.6-145.4-208.2-145.4s-170.1,65.8-219.6,167.1c-49.4-101.3-129.4-167.1-219.6-167.1-150.1,0-271.8,182.2-271.8,407s121.7,407,271.8,407,170.1-65.8,219.6-167.1c49.4,101.3,129.4,167.1,219.6,167.1s158.3-56.5,208.2-145.4c49.9,88.9,124.6,145.4,208.2,145.4,150.1,0,271.8-182.2,271.8-407s-121.7-407-271.8-407h0Z"/>
              </clipPath>
            {%- elsif frame_shape == 'website_shape_cloud' -%}
              <clipPath id="clip-{{ section.id }}" clipPathUnits="objectBoundingBox">
                <path transform="scale(0.000667)" d="M1456.6,908.5c1.1-48.6-27.9-92.4-73.6-120.5,38.5-26.3,63.1-64.7,64.1-108,1.6-70-59.4-130.1-142.8-147.7,14.5-20.4,23.1-43.8,23.6-68.9,1.8-82-82.1-150.4-187.4-152.8-4.3,0-8.5,0-12.8,0,0-.1,0-.2,0-.3,1.8-82-82.1-150.4-187.4-152.8-72.1-1.6-135.6,28.2-169,73.5-31.4-46.7-93.5-79.3-165.6-80.9-105.3-2.3-192.2,62.3-194,144.3-.1,6,.2,12,1,17.9-26.7-12-57.4-19.1-90.3-19.8-105.3-2.3-192.2,62.3-194,144.3-.9,40.9,19.5,78.4,53.2,106-78.6,16.8-136.7,72.2-138.2,139.1-1.1,50.5,30.3,95.9,79.2,123.8-38.3,26.3-62.7,64.6-63.7,107.7-1.7,75.4,69.1,139.3,162.4,150.9-11.7,18.7-18.4,39.6-18.9,61.9-1.8,82,82.1,150.4,187.4,152.8,40.3.9,77.8-8,109-23.9,27.7,54.1,94.7,93.1,173.8,94.8,61.5,1.4,116.7-20.1,152.3-54.5,29.3,15.5,64.4,24.9,102.3,25.7,100.1,2.2,183.5-56,193.1-132.2,12.3,2.2,25.1,3.6,38.2,3.8,105.3,2.3,192.2-62.3,194-144.3,0-3.6,0-7.3-.3-10.9,60.8-23.6,103-72.1,104.2-129h0Z"/>
              </clipPath>
            {%- elsif frame_shape == 'website_shape_frame' -%}
              <clipPath id="clip-{{ section.id }}" clipPathUnits="objectBoundingBox">
                <path transform="scale(0.000667)" d="M1375.6,750.6c0-55.9-31.4-104.8-78.3-131.6,52.6-25.2,88.7-77.1,88.7-137s-63.5-144.9-144.8-152.6c30.3-27.9,49.2-67,49.2-110.3,0-84.7-72.1-153.4-161-153.4s-97.2,23-126.7,58.8c-29.5-35.8-75.2-58.8-126.7-58.8s-108.8,29.2-137.2,73.1c-28.3-43.8-79.2-73.1-137.2-73.1s-106.2,27.8-134.9,69.7c-28.7-42-78.4-69.7-134.9-69.7-88.9,0-161,68.7-161,153.4s27.3,98.1,68.9,125.8c-51.6,25.5-86.9,76.9-86.9,136.2s31.4,104.8,78.3,131.6c-52.6,25.2-88.7,77.1-88.7,137s34.6,109.7,85.5,135.4c-59.7,22.4-102,77.8-102,142.7s49.5,129.3,117,147.5c-43.4,27.5-72,74.4-72,127.8,0,84.7,72.1,153.4,161,153.4s106.2-27.8,134.9-69.7c28.7,42,78.4,69.7,134.9,69.7s108.8-29.2,137.2-73.1c28.3,43.8,79.2,73.1,137.2,73.1s97.2-23,126.7-58.8c29.5,35.8,75.2,58.8,126.7,58.8,88.9,0,161-68.7,161-153.4s-25.6-95.3-65.1-123.2c75.9-12.3,133.7-75.3,133.7-151.1s-34.6-109.7-85.5-135.4c59.7-22.4,102-77.8,102-142.7h0Z"/>
              </clipPath>
            {%- elsif frame_shape == 'website_shape_pancake' -%}
              <clipPath id="clip-{{ section.id }}" clipPathUnits="objectBoundingBox">
                <path transform="scale(0.000667)" d="M1442.5,666.6c0-38.6-43-74.4-116.6-104.2,73.7-29.8,116.6-65.7,116.6-104.2,0-103.6-310-187.6-692.5-187.6S57.5,354.5,57.5,458.1s43,74.4,116.6,104.2c-73.7,29.8-116.6,65.7-116.6,104.2s33.7,66.2,92.7,93.8c-58.9,27.6-92.7,59.6-92.7,93.8s33.7,66.2,92.7,93.8c-58.9,27.6-92.7,59.6-92.7,93.8,0,103.6,310,187.6,692.5,187.6s692.5-84,692.5-187.6-33.7-66.2-92.7-93.8c58.9-27.6,92.7-59.6,92.7-93.8s-33.7-66.2-92.7-93.8c58.9-27.6,92.7-59.6,92.7-93.8Z"/>
              </clipPath>
            {%- endif -%}
          </defs>
        </svg>
      {%- endif -%}

      {%- case frame_shape -%}
        {%- when 'rounded' -%}{%- assign frame_style = 'border-radius:1rem;overflow:hidden;' -%}
        {%- when 'circle' -%}{%- assign frame_style = 'border-radius:50%;overflow:hidden;' -%}
        {%- when 'diamond' -%}{%- assign frame_style = 'clip-path:polygon(50% 0%,100% 50%,50% 100%,0% 50%);overflow:hidden;' -%}
        {%- when 'hexagon' -%}{%- assign frame_style = 'clip-path:polygon(25% 0%,75% 0%,100% 50%,75% 100%,25% 100%,0% 50%);overflow:hidden;' -%}
        {%- when 'triangle' -%}{%- assign frame_style = 'clip-path:polygon(50% 0%,100% 100%,0% 100%);overflow:hidden;' -%}
        {%- when 'arch' -%}{%- assign frame_style = 'border-radius:50% 50% 0 0/100% 100% 0 0;overflow:hidden;' -%}
        {%- when 'parallelogram' -%}{%- assign frame_style = 'clip-path:polygon(10% 0%,100% 0%,90% 100%,0% 100%);overflow:hidden;' -%}
        {%- when 'slant_left' -%}{%- assign frame_style = 'clip-path:polygon(0% 0%,100% 0%,85% 100%,0% 100%);overflow:hidden;' -%}
        {%- when 'slant_right' -%}{%- assign frame_style = 'clip-path:polygon(15% 0%,100% 0%,100% 100%,0% 100%);overflow:hidden;' -%}
        {%- when 'website_shape_star', 'website_shape_bun', 'website_shape_cloud', 'website_shape_frame', 'website_shape_pancake' -%}
          {%- assign frame_style = 'clip-path:url(#clip-' | append: section.id | append: ');overflow:hidden;' -%}
        {%- else -%}
          {%- assign frame_style = '' -%}
      {%- endcase -%}

      <div class="section-content relative z-10 mx-auto w-full text-center" style="{{ frame_style }}">
        {% if section.settings.mode == 'preview' %}
          {% liquid
            if section.settings.style == 'inset'
              assign sizes = 'min(1820px, 100vw)'
            else
              assign sizes = '100vw'
            endif
          %}
          {% capture video_preview %}
            {% if video %}
              {% liquid
                assign preview_class = 'object-cover relative w-full h-full'

                if section.settings.style == 'inset'
                  assign preview_class = preview_class | append: ' media__styled-element'
                endif
              %}
              {{
                video.preview_image
                | image_url: width: 4000
                | image_tag: class: preview_class, sizes: sizes
              }}
            {% else %}
              {% liquid
                assign placeholder_svg_class = 'block relative h-full w-full object-cover text-scheme-placeholder-foreground fill-current bg-neutral-100'

                if section.settings.style == 'inset'
                  assign placeholder_svg_class = placeholder_svg_class | append: ' media__styled-element'
                endif
              %}
              {{ 'lifestyle-1' | placeholder_svg_tag: placeholder_svg_class }}
            {% endif %}
            <div class="absolute inset-0 z-10 grid h-full w-full place-content-center">
              <span class="sr-only">{{ 'general.video.play' | t }}</span>
              <div class="push-btn">
                <div
                  class="push-btn__surface p-2 align-bottom"
                  style="background-color: {{ play_btn_bg }};"
                >
                  <div class="p-2.5" style="color: {{ play_btn_color }};">
                    <div class="h-10 w-10">
                      {% render 'icon-play' %}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          {% endcapture %}
          {% if section.settings.playback == 'modal' %}
            <button
              x-data
              class="relative block w-full cursor-pointer"
              type="button"
              title="{{ 'general.video.play' | t }}{% if video.alt %}, {{ video.alt | escape }}{% endif %}"
              @click="$store.modals.open('{{ video_modal_id }}')"
              style="padding-top: {{ ratio }}%;"
            >
              <div
                class="{% if section.settings.style == 'inset' %}media media--css-only absolute{% else %}absolute{% endif %} pointer-events-none inset-0 h-full w-full"
              >
                {{ video_preview }}
              </div>
            </button>
          {% else %}
            <data-island
              id="video-{{ section.id }}"
              x-data="Video('inline')"
              class="relative w-full"
              x-intersect:leave="pause"
              style="padding-top: {{ ratio }}%;"
            >
              <div
                class="{% if section.settings.style == 'inset' %}media media--css-only absolute{% else %}absolute{% endif %} inset-0 h-full w-full"
              >
                <template x-if="enabled">
                  <div
                    class="contents"
                    x-data="HTMLVideo"
                    @play="play"
                    @pause="pause"
                  >
                    {% liquid
                      assign video_tag_class = 'absolute inset-0 w-full h-full object-cover z-20'

                      if section.settings.style == 'inset'
                        assign video_tag_class = video_tag_class | append: ' media__styled-element'
                      endif
                    %}
                    {% if video %}
                      {{
                        video
                        | video_tag:
                          class: video_tag_class,
                          image_size: '2000x',
                          controls: true,
                          autoplay: true,
                          muted: false,
                          playsline: true,
                          x-ref: 'video'
                      }}
                    {% else %}
                      <video
                        x-ref="video"
                        autoplay
                        controls
                        playsinline
                        class="{{ video_tag_class }}"
                      >
                        <source
                          src="{{ 'placeholder-video.mp4' | asset_url }}"
                          type="video/mp4"
                        >
                        Your browser does not support the video tag.
                      </video>
                    {% endif %}
                  </div>
                </template>
                <button
                  class="absolute inset-0 h-full w-full cursor-pointer"
                  type="button"
                  title="{{ 'general.video.play' | t }}{% if video.alt %}, {{ video.alt | escape }}{% endif %}"
                  @click="enabled = true"
                >
                  {{ video_preview }}
                </button>
              </div>
            </data-island>
          {% endif %}
        {% else %}
          <data-island
            id="video-{{ section.id }}"
            x-data="Video('inline', 'autoplay')"
            class="relative w-full"
            x-intersect:leave="pause"
            x-intersect:enter="play"
            style="padding-top: {{ ratio }}%;"
          >
            <div
              class="{% if section.settings.style == 'inset' %}media media--css-only absolute top-0 left-0 right-0 bottom-0 w-full h-full{% endif %}"
              :class="{ 'opacity-0 pointer-events-none' : !shown }"
            >
              <data-island
                class="contents"
                x-data="HTMLVideo"
                @play="play"
                @pause="pause"
              >
                {% liquid
                  assign video_tag_class = 'absolute inset-0 w-full h-full object-cover'

                  if section.settings.style == 'inset'
                    assign video_tag_class = video_tag_class | append: ' media__styled-element'
                  endif
                %}
                {% if video %}
                  {{
                    video
                    | video_tag:
                      class: video_tag_class,
                      image_size: '2000x',
                      controls: false,
                      autoplay: true,
                      playsline: true,
                      x-ref: 'video'
                  }}
                {% else %}
                  <video
                    x-ref="video"
                    autoplay
                    playsinline
                    class="{{ video_tag_class }}"
                  >
                    <source
                      src="{{ 'placeholder-video.mp4' | asset_url }}"
                      type="video/mp4"
                    >
                    Your browser does not support the video tag.
                  </video>
                {% endif %}
              </data-island>
            </div>
          </data-island>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{%- liquid
  if section.settings.mode == 'preview' and section.settings.playback == 'modal'
    render 'video-modal', video: video, video_modal_id: video_modal_id
  endif

  assign stickers = section.blocks | where: 'type', 'sticker'
  assign shape_dividers = section.blocks | where: 'type', 'shape_divider'
  assign no_padding = true

  if section.settings.style == 'inset'
    assign no_padding = false
  endif

  for sticker in stickers
    render 'block-sticker', block: sticker
  endfor

  for shape_divider in shape_dividers
    render 'block-shape-divider', block: shape_divider, no_padding: no_padding
  endfor
-%}

{% schema %}
{
  "name": "t:sections.video.name",
  "settings": [
    {
      "id": "title",
      "type": "inline_richtext",
      "label": "t:common.settings.title.label"
    },
    {
      "type": "header",
      "content": "t:common.settings.header_layout"
    },
    {
      "type": "select",
      "id": "style",
      "label": "t:common.settings.style.label",
      "default": "full",
      "options": [
        {
          "value": "inset",
          "label": "t:common.options.inset.label"
        },
        {
          "value": "full",
          "label": "t:common.options.full_width.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "t:sections.video.settings.aspect_ratio.label",
      "default": "natural",
      "options": [
        {
          "value": "natural",
          "label": "t:common.options.natural.label"
        },
        {
          "value": "4:3",
          "label": "t:sections.video.settings.aspect_ratio.options.standard_4_3.label"
        },
        {
          "value": "16:9",
          "label": "t:sections.video.settings.aspect_ratio.options.widescreen_16_9.label"
        },
        {
          "value": "2.35:1",
          "label": "t:sections.video.settings.aspect_ratio.options.extra-wide_235_1.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "Video Frame"
    },
    {
      "type": "select",
      "id": "video_frame_shape",
      "label": "Frame Shape",
      "default": "default",
      "info": "Applies a shape mask to the video frame. Note: some shapes work best with the 'Inset' layout style.",
      "options": [
        {
          "value": "default",
          "label": "Default (Rectangle)"
        },
        {
          "value": "rounded",
          "label": "Rounded"
        },
        {
          "value": "circle",
          "label": "Circle"
        },
        {
          "value": "arch",
          "label": "Arch"
        },
        {
          "value": "diamond",
          "label": "Diamond"
        },
        {
          "value": "hexagon",
          "label": "Hexagon"
        },
        {
          "value": "triangle",
          "label": "Triangle"
        },
        {
          "value": "parallelogram",
          "label": "Parallelogram"
        },
        {
          "value": "slant_left",
          "label": "Slant Left"
        },
        {
          "value": "slant_right",
          "label": "Slant Right"
        },
        {
          "value": "website_shape_star",
          "label": "Star (Custom)"
        },
        {
          "value": "website_shape_bun",
          "label": "Bun (Custom)"
        },
        {
          "value": "website_shape_cloud",
          "label": "Cloud (Custom)"
        },
        {
          "value": "website_shape_frame",
          "label": "Frame (Custom)"
        },
        {
          "value": "website_shape_pancake",
          "label": "Pancake (Custom)"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:common.settings.header_video"
    },
    {
      "id": "video",
      "type": "video",
      "label": "t:sections.video.settings.video.label"
    },
    {
      "type": "select",
      "id": "mode",
      "label": "Mode",
      "options": [
        {
          "value": "preview",
          "label": "t:sections.video.settings.mode.options.preview.label"
        },
        {
          "value": "autoplay",
          "label": "t:sections.video.settings.mode.options.autoplay.label"
        }
      ],
      "default": "preview",
      "info": "t:sections.video.settings.mode.info"
    },
    {
      "type": "select",
      "id": "playback",
      "label": "t:sections.video.settings.playback.label",
      "options": [
        {
          "value": "inline",
          "label": "t:sections.video.settings.playback.options.inline.label"
        },
        {
          "value": "modal",
          "label": "t:sections.video.settings.playback.options.modal.label"
        }
      ],
      "default": "inline",
      "info": "t:sections.video.settings.playback.info"
    },
    {
      "type": "header",
      "content": "Play Button"
    },
    {
      "type": "color",
      "id": "play_button_background_color",
      "label": "Button Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "play_button_icon_color",
      "label": "Button Icon Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "t:common.settings.header_color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme1",
      "label": "t:common.settings.color_scheme.label"
    },
    {
      "type": "checkbox",
      "id": "use_gradient_background",
      "label": "t:common.settings.use_gradient_background.label"
    }
  ],
  "blocks": [
    {
      "type": "background_pattern",
      "name": "t:common.blocks.background_pattern.name",
      "settings": [
        {
          "type": "select",
          "id": "type",
          "label": "t:common.blocks.background_pattern.settings.type.label",
          "options": [
            {
              "value": "diagonal_lines",
              "label": "t:common.options.diagonal_lines.label",
              "group": "t:common.blocks.background_pattern.settings.type.options.group_lines"
            },
            {
              "value": "grid",
              "label": "t:common.options.grid_lines.label",
              "group": "t:common.blocks.background_pattern.settings.type.options.group_lines"
            },
            {
              "value": "grid_with_diagonal_lines",
              "label": "t:common.options.grid_with_diagonal_lines.label",
              "group": "t:common.blocks.background_pattern.settings.type.options.group_lines"
            },
            {
              "value": "crosshatch",
              "label": "t:common.options.crosshatch.label",
              "group": "t:common.blocks.background_pattern.settings.type.options.group_lines"
            },
            {
              "value": "zig_zag_lines",
              "label": "t:common.options.zig_zag.label",
