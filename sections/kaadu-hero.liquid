<svg width="0" height="0" aria-hidden="true" focusable="false" style="position:absolute;overflow:hidden">
  <defs>
    <clipPath id="kaadu-star-{{ section.id }}" clipPathUnits="objectBoundingBox">
      <path transform="scale(0.005,0.005)" d="{{ star_path }}" />
    </clipPath>
  </defs>
</svg>

<section id="kaadu-hero-{{ section.id }}" class="kaadu-hero">
  <div class="kaadu-hero__inner">

    {%- comment -%} ── Image composition ── {%- endcomment -%}
    <div class="kaadu-hero__image-col">
      <div class="kaadu-hero__star-wrap">
        <div class="kaadu-hero__star-bg" style="clip-path:url(#kaadu-star-{{ section.id }})">
          {%- if section.settings.background_image != blank -%}
            {{
              section.settings.background_image
              | image_url: width: 800
              | image_tag:
                loading: loading,
                widths: '400,600,800',
                sizes: '(min-width: 769px) 55vw, 100vw',
                alt: section.settings.background_image.alt | escape,
                class: 'kaadu-hero__star-bg-img'
            }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'kaadu-hero__star-bg-img kaadu-hero__star-bg-img--placeholder' }}
          {%- endif -%}
        </div>
        {%- if section.settings.product_image != blank -%}
          <div class="kaadu-hero__product-wrap">
            {{
              section.settings.product_image
              | image_url: width: 600
              | image_tag:
                loading: loading,
                widths: '300,500,600',
                sizes: '(min-width: 769px) 40vw, 85vw',
                alt: section.settings.product_image.alt | escape,
                class: 'kaadu-hero__product-img'
            }}
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ── Content column ── {%- endcomment -%}
    <div class="kaadu-hero__content-col">
      {%- if section.settings.eyebrow_text != blank -%}
        <p class="kaadu-hero__eyebrow">{{ section.settings.eyebrow_text | escape }}</p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="kaadu-hero__heading">{{ section.settings.title }}</h2>
      {%- endif -%}

      {%- if section.settings.richtext != blank -%}
        <div class="kaadu-hero__body rte">{{ section.settings.richtext }}</div>
      {%- endif -%}

      <div class="kaadu-hero__buttons">
        {%- if section.settings.button1_label != blank -%}
          <a
            href="{{ section.settings.button1_link | default: '#' }}"
            class="kaadu-hero__btn-shape"
            {%- if section.settings.button1_shape_image != blank -%}
              style="background-image:url('{{ section.settings.button1_shape_image | image_url: width: 600 }}')"
            {%- endif -%}
          >
            {{- section.settings.button1_label | escape -}}
          </a>
        {%- endif -%}

        {%- if section.settings.button2_label != blank -%}
          <a href="{{ section.settings.button2_link | default: '#' }}" class="kaadu-hero__btn-pill">
            {{- section.settings.button2_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

<style>
  /* ── kaadu-hero ── */
  #kaadu-hero-{{ section.id }} {
    background-color: var(--color-brand-pink, #ffc5ff);
    width: 100%;
    overflow: hidden;
    padding: 32px 20px 40px;
  }

  #kaadu-hero-{{ section.id }} .kaadu-hero__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  /* Image column */
  #kaadu-hero-{{ section.id }} .kaadu-hero__image-col {
    width: 100%;
    max-width: 400px;
  }

  #kaadu-hero-{{ section.id }} .kaadu-hero__star-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
  }

  #kaadu-hero-{{ section.id }} .kaadu-hero__star-bg {
    position: absolute;
    inset: 0;
  }

  #kaadu-hero-{{ section.id }} .kaadu-hero__star-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #kaadu-hero-{{ section.id }} .kaadu-hero__star-bg-img--placeholder {
    background-color: var(--color-brand-lime, #acff64);
  }

  #kaadu-hero-{{ section.id }} .kaadu-hero__product-wrap {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #kaadu-hero-{{ section.id }} .kaadu-hero__product-img {
    width: 88%;
    height: 88%;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 8px 20px rgba(0,0,0,0.22));
  }

  /* Content column */
  #kaadu-hero-{{ section.id }} .kaadu-hero__content-col {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
  }

  #kaadu-hero-{{ section.id }} .kaadu-hero__eyebrow {
    font-family: var(--font-heading, 'Banter Grotesk', Helvetica, sans-serif);
    font-weight: 600;
    font-size: 14px;
    line-height: 24px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-ink, #201920);
    margin: 0;
  }

  #kaadu-hero-{{ section.id }} .kaadu-hero__heading {
    font-family: var(--font-display, 'Fagies', Helvetica, sans-serif);
    font-weight: 400;
    font-size: 48px;
    line-height: 1;
    text-transform: uppercase;
    color: var(--color-brand-red, #ae0000);
    margin: 0;
    word-break: break-word;
  }

  #kaadu-hero-{{ section.id }} .kaadu-hero__body {
    font-family: var(--font-body, 'Banter Grotesk', Helvetica, sans-serif);
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-ink, #201920);
    margin: 0;
    max-width: 480px;
  }

  #kaadu-hero-{{ section.id }} .kaadu-hero__body p {
    margin: 0 0 8px;
  }

  #kaadu-hero-{{ section.id }} .kaadu-hero__body p:last-child {
    margin-bottom: 0;
  }

  /* Buttons */
  #kaadu-hero-{{ section.id }} .kaadu-hero__buttons {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    margin-top: 4px;
  }

  /* Lime shape button */
  #kaadu-hero-{{ section.id }} .kaadu-hero__btn-shape {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 53px;
    width: 100%;
    padding: 14px 24px;
    background-color: var(--color-brand-lime, #acff64);
    background-size: 100% 100%;
    background-repeat: no-repeat;
    background-position: center;
    border: none;
    border-radius: 4px;
    font-family: var(--font-heading, 'Banter Grotesk', Helvetica, sans-serif);
    font-weight: 600;
    font-size: 16px;
    line-height: 1.5;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-brand-purple, #542a76);
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0,0,0,0.25);
    transition: filter 0.2s ease-out, transform 0.2s ease-out;
  }

  #kaadu-hero-{{ section.id }} .kaadu-hero__btn-shape:hover {
    filter: brightness(0.95);
    transform: translateY(-2px);
  }

  /* Pill button */
  #kaadu-hero-{{ section.id }} .kaadu-hero__btn-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    width: 100%;
    padding: 12px 28px;
    background-color: var(--color-offwhite, #fffff5);
    border: 2px solid var(--color-ink, #201920);
    border-radius: 30px;
    font-family: var(--font-heading, 'Banter Grotesk', Helvetica, sans-serif);
    font-weight: 600;
    font-size: 16px;
    line-height: 1.5;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-ink, #201920);
    text-decoration: none;
    box-shadow: 0 4px 4px rgba(0,0,0,0.25);
    transition: transform 0.2s ease-out, box-shadow 0.2s ease-out;
  }

  #kaadu-hero-{{ section.id }} .kaadu-hero__btn-pill:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 8px rgba(0,0,0,0.3);
  }

  /* ── Desktop ── */
  @media (min-width: 769px) {
    #kaadu-hero-{{ section.id }} {
      padding: 64px 48px;
    }

    #kaadu-hero-{{ section.id }} .kaadu-hero__inner {
      flex-direction: row;
      align-items: center;
      gap: 56px;
    }

    #kaadu-hero-{{ section.id }} .kaadu-hero__image-col {
      flex: 0 0 55%;
      max-width: 55%;
    }

    #kaadu-hero-{{ section.id }} .kaadu-hero__content-col {
      flex: 1 1 0;
      align-items: flex-start;
      text-align: left;
    }

    #kaadu-hero-{{ section.id }} .kaadu-hero__heading {
      font-size: 72px;
    }

    #kaadu-hero-{{ section.id }} .kaadu-hero__body {
      font-size: 18px;
      max-width: none;
    }

    #kaadu-hero-{{ section.id }} .kaadu-hero__buttons {
      flex-direction: row;
      gap: 16px;
    }

    #kaadu-hero-{{ section.id }} .kaadu-hero__btn-shape,
    #kaadu-hero-{{ section.id }} .kaadu-hero__btn-pill {
      flex: 1;
      font-size: 18px;
      width: auto;
    }
  }
</style>

{% schema %}
{
  "name": "Kaadu Hero",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
      "placeholder": "JUSTICE NEVER TASTED SO SWEET"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "default": "100% FRUCHT<br>100% FAIR"
    },
    {
      "type": "richtext",
      "id": "richtext",
      "label": "Body text"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Star background photo",
      "info": "Photo clipped inside the star shape"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image",
      "info": "Overlaid on top of the star"
    },
    {
      "type": "header",
      "content": "Primary button (lime shape)"
    },
    {
      "type": "text",
      "id": "button1_label",
      "label": "Label",
      "default": "PROBIERPAKET BESTELLEN"
    },
    {
      "type": "url",
      "id": "button1_link",
      "label": "Link"
    },
    {
      "type": "image_picker",
      "id": "button1_shape_image",
      "label": "Shape background image",
      "info": "Upload the lime wavy/jagged shape asset. Falls back to solid lime if empty."
    },
    {
      "type": "header",
      "content": "Secondary button (pill)"
    },
    {
      "type": "text",
      "id": "button2_label",
      "label": "Label",
      "default": "SHOP ÖFFNEN"
    },
    {
      "type": "url",
      "id": "button2_link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Kaadu Hero"
    }
  ]
}
{% endschema %}
